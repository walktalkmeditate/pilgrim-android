    <string name="onboarding_title">A few doors to open</string>
    <string name="onboarding_subtitle">Pilgrim needs a small set of permissions before you walk. Nothing you grant leaves this device.</string>

    <string name="permission_location_title">Your place in the world</string>
    <string name="permission_location_rationale">To draw the path your feet trace, Pilgrim reads the device\'s precise location while a walk is in progress. Your coordinates stay on this device — no account, no cloud.</string>

    <string name="permission_notification_title">A quiet notification</string>
    <string name="permission_notification_rationale">Android needs to see an ongoing notification to keep the walk recording reliably when the screen is off. It shows your time and distance.</string>

    <string name="permission_activity_title">Footsteps</string>
    <string name="permission_activity_rationale">If you\'d like Pilgrim to count your steps, it reads the device\'s motion sensor. This is optional — skip it and the walk still works.</string>

