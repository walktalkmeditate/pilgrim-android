<?xml version="1.0" encoding="utf-8"?>
<!--
  FileProvider roots for files Pilgrim shares via ACTION_SEND.

  - etegami/         (Stage 7-D) Shared etegami PNG postcards. Swept by
                     EtegamiCacheSweeper after 24h; Android also
                     auto-clears cacheDir on storage pressure.
  - recordings_export/ (Stage 10-G) Voice recordings ZIP exports
                     produced from Settings → Data → Export Recordings.
                     No app-side sweeper; the OS clears cacheDir on
                     storage pressure.
-->
<paths xmlns:android="http://schemas.android.com/apk/res/android">
    <cache-path name="etegami_cache" path="etegami/" />
    <cache-path name="recordings_export" path="recordings_export/" />
</paths>
