<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <!-- ACCESS_BACKGROUND_LOCATION is intentionally NOT declared: our
         foreground service with foregroundServiceType=location covers the
         entire walk lifecycle, so we never read location from a pure
         background state. Declaring it would trigger Play Store's
         enhanced review process for no gain. -->
    <uses-permission android:name="android.permission.ACTIVITY_RECOGNITION" />
    <!-- Runtime mic permission for voice recording during walks.
         Requested just-in-time at record-button tap (see Stage 2-C),
         not front-loaded into onboarding. -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_LOCATION" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <!-- Required to launch the battery-optimization exemption prompt directly
         via ACTION_REQUEST_IGNORE_BATTERY_OPTIMIZATIONS. Justified by our
         foreground-service-with-ongoing-notification location tracking. -->
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />
    <!-- Mapbox tile downloads. -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <application
        android:name=".PilgrimApp"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Pilgrim"
        tools:targetApi="36">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.Pilgrim">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <service
            android:name=".service.WalkTrackingService"
            android:exported="false"
            android:foregroundServiceType="location"
            android:stopWithTask="false" />

        <!-- WorkManager is initialized via Configuration.Provider in
             PilgrimApp so its WorkerFactory can access Hilt-bound
             dependencies. The androidx.startup InitializationProvider
             would otherwise invoke WorkManagerInitializer with the
             default Configuration. -->
        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="${applicationId}.androidx-startup"
            android:exported="false"
            tools:node="merge">
            <meta-data
                android:name="androidx.work.WorkManagerInitializer"
                android:value="androidx.startup"
                tools:node="remove" />
        </provider>

        <!-- Stage 7-A: No Play Services Photo Picker backport is wired
             here. Activating the backport would require adding
             com.google.android.gms:play-services-picker and publishing
             the ModuleDependencies <service>. API 28-29 devices
             therefore fall back to SAF (ACTION_OPEN_DOCUMENT) — a
             file-browser UI rather than the photo grid, but
             functionally correct for picking an image. API 30+ uses
             the native Photo Picker directly. Re-evaluate wiring the
             backport in a later stage if API-28-29 usage is
             meaningful. -->

    </application>
</manifest>
